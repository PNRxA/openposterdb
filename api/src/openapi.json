{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenPosterDB API",
    "description": "API for generating and serving posters, logos, and backdrops with rating overlays for movies, TV shows, and collections.",
    "version": "{{VERSION}}",
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "This instance"
    }
  ],
  "paths": {
    "/{api_key}/{id_type}/poster-default/{id_value}": {
      "get": {
        "operationId": "getPoster",
        "summary": "Get poster",
        "description": "Returns a JPEG poster image with rating badge overlays for the given media item.",
        "tags": ["Images"],
        "parameters": [
          { "$ref": "#/components/parameters/ApiKey" },
          { "$ref": "#/components/parameters/IdType" },
          { "$ref": "#/components/parameters/IdValue" },
          { "$ref": "#/components/parameters/Fallback" },
          { "$ref": "#/components/parameters/Lang" },
          { "$ref": "#/components/parameters/ImageSize" }
        ],
        "responses": {
          "200": {
            "description": "Poster image",
            "content": {
              "image/jpeg": {
                "schema": { "type": "string", "format": "binary" }
              }
            },
            "headers": {
              "Cache-Control": {
                "schema": { "type": "string", "example": "public, max-age=3600, stale-while-revalidate=86400" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/{api_key}/{id_type}/logo-default/{id_value}": {
      "get": {
        "operationId": "getLogo",
        "summary": "Get logo",
        "description": "Returns a PNG logo image with rating badge overlays for the given media item. Requires the Fanart.tv integration to be configured on the server.",
        "tags": ["Images"],
        "parameters": [
          { "$ref": "#/components/parameters/ApiKey" },
          { "$ref": "#/components/parameters/IdType" },
          { "$ref": "#/components/parameters/IdValue" },
          { "$ref": "#/components/parameters/Fallback" },
          { "$ref": "#/components/parameters/Lang" },
          { "$ref": "#/components/parameters/ImageSize" }
        ],
        "responses": {
          "200": {
            "description": "Logo image",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              }
            },
            "headers": {
              "Cache-Control": {
                "schema": { "type": "string", "example": "public, max-age=3600, stale-while-revalidate=86400" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "501": { "$ref": "#/components/responses/FanartNotConfigured" }
        }
      }
    },
    "/{api_key}/{id_type}/backdrop-default/{id_value}": {
      "get": {
        "operationId": "getBackdrop",
        "summary": "Get backdrop",
        "description": "Returns a JPEG backdrop image with rating badge overlays for the given media item. Requires the Fanart.tv integration to be configured on the server.",
        "tags": ["Images"],
        "parameters": [
          { "$ref": "#/components/parameters/ApiKey" },
          { "$ref": "#/components/parameters/IdType" },
          { "$ref": "#/components/parameters/IdValue" },
          { "$ref": "#/components/parameters/Fallback" },
          { "$ref": "#/components/parameters/Lang" },
          { "$ref": "#/components/parameters/ImageSize" }
        ],
        "responses": {
          "200": {
            "description": "Backdrop image",
            "content": {
              "image/jpeg": {
                "schema": { "type": "string", "format": "binary" }
              }
            },
            "headers": {
              "Cache-Control": {
                "schema": { "type": "string", "example": "public, max-age=3600, stale-while-revalidate=86400" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "501": { "$ref": "#/components/responses/FanartNotConfigured" }
        }
      }
    },
    "/{api_key}/isValid": {
      "get": {
        "operationId": "isValid",
        "summary": "Validate API key",
        "description": "Returns 200 OK if the provided API key is valid. Useful for verifying that an API key is correctly configured.",
        "tags": ["Auth"],
        "parameters": [
          { "$ref": "#/components/parameters/ApiKey" }
        ],
        "responses": {
          "200": {
            "description": "API key is valid"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ApiKey": {
        "name": "api_key",
        "in": "path",
        "required": true,
        "description": "Your API key (64-character hex string). Use `t0-free-rpdb` as a free public key if enabled on this instance.",
        "schema": { "type": "string" }
      },
      "IdType": {
        "name": "id_type",
        "in": "path",
        "required": true,
        "description": "The type of media ID being used.",
        "schema": {
          "type": "string",
          "enum": ["imdb", "tmdb", "tvdb"]
        }
      },
      "IdValue": {
        "name": "id_value",
        "in": "path",
        "required": true,
        "description": "The media ID value. For IMDB use the `tt` prefixed ID (e.g. `tt1234567`). For TMDB prefix with `movie-` or `series-` (e.g. `movie-550`, `series-1399`). For TVDB use the numeric ID.",
        "schema": { "type": "string" }
      },
      "Fallback": {
        "name": "fallback",
        "in": "query",
        "required": false,
        "description": "When set to `true`, returns a placeholder image instead of 404 when the media item is not found.",
        "schema": { "type": "string", "enum": ["true"] }
      },
      "Lang": {
        "name": "lang",
        "in": "query",
        "required": false,
        "description": "Language code for Fanart.tv image selection (e.g. `en`, `de`, `pt-BR`). 2-5 alphanumeric characters or hyphens.",
        "schema": { "type": "string", "pattern": "^[a-zA-Z0-9-]{2,5}$" }
      },
      "ImageSize": {
        "name": "imageSize",
        "in": "query",
        "required": false,
        "description": "Output image size. `small` is only valid for backdrops. Defaults to `medium`.",
        "schema": {
          "type": "string",
          "enum": ["small", "medium", "large", "very-large"],
          "default": "medium"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request — bad ID type, image size, or language format."
      },
      "Unauthorized": {
        "description": "Invalid or missing API key."
      },
      "NotFound": {
        "description": "Media item not found. Use `?fallback=true` to get a placeholder image instead."
      },
      "FanartNotConfigured": {
        "description": "Fanart.tv integration is not configured on this server. Logos and backdrops require a Fanart.tv API key."
      }
    }
  },
  "tags": [
    { "name": "Images", "description": "Poster, logo, and backdrop image endpoints" },
    { "name": "Auth", "description": "API key validation" }
  ]
}
